# Environment variables for {{cookiecutter.project_name}}
# Copy this file to .env and fill in the required values

# ============================================================================
# LLM Configuration
# ============================================================================

# Model provider to use: google, anthropic, openai, or litellm
# Default: google (Gemini 2.0 Flash)
MODEL_PROVIDER={{cookiecutter.model_provider}}

# Full model string for litellm provider
# Only required when MODEL_PROVIDER=litellm
# Examples: "anthropic/claude-opus-4-8", "openai/gpt-4o"
# LITELLM_MODEL=

# Anthropic API key for Claude models
# Only required when MODEL_PROVIDER=anthropic
# Get one at: https://console.anthropic.com
# ANTHROPIC_API_KEY=

# OpenAI API key for GPT models
# Only required when MODEL_PROVIDER=openai
# Get one at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ============================================================================
# Google Cloud Configuration (Required)
# ============================================================================

# Google Cloud Project ID where the agent will be deployed
GOOGLE_CLOUD_PROJECT={{cookiecutter.gcp_project_id}}

# Google Cloud location/region for agent deployment
# Default: europe-west1
GOOGLE_CLOUD_LOCATION={{cookiecutter.gcp_location}}

# GCS bucket for staging agent code during deployment
# Should be in the format: gs://bucket-name
# GCS_STAGING_BUCKET=

# Google API key for local development (not needed on GCP with ADC)
# Get one at: https://cloud.google.com/docs/authentication/api-keys
GOOGLE_API_KEY=

# ============================================================================
# Agent Engine Configuration (Optional)
# ============================================================================

# Resource name of an existing Agent Engine to update
# Leave empty to create a new agent on deployment
# Format: projects/{project}/locations/{location}/agentEngines/{id}
# AGENT_ENGINE_RESOURCE_NAME=

# ============================================================================
# Tool Integrations (Optional)
# ============================================================================

# SerpAPI key for web search functionality
# Get one at: https://serpapi.com
# Leave empty to use stub search results
# SERPAPI_API_KEY=
