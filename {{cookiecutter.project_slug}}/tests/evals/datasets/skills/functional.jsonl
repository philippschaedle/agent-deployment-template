{"description": "structured list", "vars": {"prompt": "List 3 benefits of regular exercise"}, "assert": [{"type": "contains-any", "value": ["weight", "disease", "mood", "energy", "sleep", "health", "strength"]}]}
{"description": "factual: basic arithmetic", "vars": {"prompt": "What is 7 multiplied by 8?"}, "assert": [{"type": "contains", "value": "56"}]}
{"description": "factual: water boiling point", "vars": {"prompt": "At what temperature does water boil at sea level in Celsius?"}, "assert": [{"type": "contains", "value": "100"}]}
