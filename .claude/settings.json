{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/pre-commit-checks.sh",
            "if": "Bash(git commit *)",
            "timeout": 30,
            "statusMessage": "Checking markdown and workflow syntax..."
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": true,
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": ["~/.claude"],
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(secrets/**)",
      "Read(**/*.secret)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(secrets/**)",
      "Write(**/*.secret)",
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(chmod 777 *)",
      "Bash(sudo *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(dd *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(crontab *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)"
    ]
  }
}
